// server/prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

enum Role {
  admin
  trainer
  member
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(member)
  createdAt DateTime @default(now())

  member     Member?
  trainer    Trainer?
  attendance Attendance[]
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum AttendanceMethod {
  SENSOR_FACE
  SENSOR_QR
  SENSOR_RFID
  MANUAL_TRAINER
  MANUAL_ADMIN
}

model Attendance {
  id           Int              @id @default(autoincrement())
  userId       Int
  classId      Int?
  status       AttendanceStatus
  method       AttendanceMethod
  checkInTime  DateTime         @default(now())
  checkOutTime DateTime?

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  class Class? @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([classId])
  @@index([checkInTime])
  @@index([status])
}

model Member {
  id               Int                @id @default(autoincrement())
  userId           Int                @unique
  memberNo         String?            // Unique member number, set on create

  // Basic profile
  age              Int                @default(25)
  gender           String?
  dob              DateTime?
  mobile           String?
  address          String?
  occupation       String?

  // Fitness
  height           Float              @default(170)
  weight           Float              @default(70)
  fitnessGoal      String             @default("weight_loss")

  // Membership
  membershipType   String             @default("basic")
  membershipPackage String?           // e.g. "3_month", "6_month", "1_year"
  membershipAmount Float?
  joinDate         DateTime           @default(now())
  membershipDueDate DateTime?
  sessionTime      String?            // "morning" | "evening" | "flexible"

  // Guardian / Emergency Contact
  guardianName     String?
  guardianRelation String?
  guardianMobile   String?

  lastAttendance   DateTime?
  trainerId        Int?

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainer          Trainer?           @relation(fields: [trainerId], references: [id], onDelete: SetNull)
  workoutRequests  WorkoutRequest[]
  workoutPlans     WorkoutPlan[]
  measurements     BodyMeasurement[]
  reviews          TrainerReview[]

  @@index([fitnessGoal])
  @@index([membershipType])
  @@index([memberNo])
}

model BodyMeasurement {
  id               Int      @id @default(autoincrement())
  memberId         Int
  measuredAt       DateTime @default(now())
  recordedBy       Int?     // trainer userId who recorded it
  notes            String?

  // Vitals
  weight           Float?
  height           Float?

  // Circumferences (cm)
  neck             Float?
  shoulder         Float?
  chest            Float?   // normal chest
  upperArm         Float?
  forearm          Float?
  wrist            Float?
  upperAbdomen     Float?
  waist            Float?
  lowerAbdomen     Float?
  hips             Float?
  thigh            Float?
  calf             Float?
  ankle            Float?

  // BCA Report
  bodyFat          Float?   // B.F %
  visceralFat      Float?   // V.F
  restingMetabolism Float?  // R.M (kcal)
  bmi              Float?   // B.M.I
  biologicalAge    Int?     // B.A

  member           Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId])
  @@index([measuredAt])
}

model Trainer {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique

  // Profile
  photo            String?  // base64 or URL
  mobile           String?
  gender           String?
  age              Int?
  address          String?
  weight           Float?
  height           Float?

  // Professional
  specialization   String   @default("General Fitness")
  specializations  String[] @default([])
  trainerType      String   @default("general") // personal | general | common
  experience       Int      @default(1)
  salary           Float?
  gymJoinDate      DateTime?
  successRate      Float?   // percentage
  isActive         Boolean  @default(true)

  // Certifications & Journey
  certificates     String[] @default([])
  fitnessJourney   String?
  termsConditions  String?

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  members          Member[]
  classes          Class[]
  reviews          TrainerReview[]
  workoutPlans     WorkoutPlan[]
}

model TrainerReview {
  id               Int      @id @default(autoincrement())
  trainerId         Int
  memberId          Int
  rating           Int      @default(5)
  comment          String?
  createdAt        DateTime @default(now())

  trainer          Trainer  @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  member           Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([trainerId])
  @@index([memberId])
}

model WorkoutRequest {
  id              Int      @id @default(autoincrement())
  memberId        Int
  fitnessGoal     String
  experienceLevel String
  planDuration    Int      @default(7) // Days
  targetFocus     String?  // Optional focus area
  daysPerWeek     Int      @default(3)
  sessionTime     Int      @default(60) // Minutes
  equipment       String[] @default([])
  intensity       String   @default("moderate")
  recoveryOption  String?  // Stretching, Yoga, etc.
  injuries        String?
  status          String   @default("pending") // pending | generated | fulfilled
  createdAt       DateTime @default(now())

  member          Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  workoutPlan     WorkoutPlan?
}

model WorkoutPlan {
  id             Int               @id @default(autoincrement())
  memberId       Int
  requestId      Int?              @unique
  name           String
  goal           String
  duration       Int               @default(7)
  difficulty     String
  status         String            @default("pending") // pending | active | completed
  isAiGenerated  Boolean           @default(true)
  isTrainerEdited Boolean          @default(false)
  trainerId      Int?              // The trainer who reviewed/edited it
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  member         Member            @relation(fields: [memberId], references: [id], onDelete: Cascade)
  request        WorkoutRequest?   @relation(fields: [requestId], references: [id])
  trainer        Trainer?          @relation(fields: [trainerId], references: [id], onDelete: SetNull)
  exercises      WorkoutExercise[]

  @@index([memberId])
  @@index([status])
}

model WorkoutExercise {
  id            Int         @id @default(autoincrement())
  planId        Int
  day           Int         // Day 1, Day 2, etc.
  dayTitle      String?     // e.g. "Chest + Triceps"
  name          String
  sets          Int
  reps          String      // String to handle "10-12" or "failure"
  restTime      Int         @default(60) // Seconds
  instructions  String
  targetMuscle  String
  order         Int         @default(0)

  plan          WorkoutPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model Exercise {
  id           Int           @id @default(autoincrement())
  name         String
  muscleGroup  String
  difficulty   String        @default("beginner")
  instructions String
  equipment    String[]      @default([])
  videoUrl     String?

  @@index([muscleGroup])
  @@index([difficulty])
}

model Class {
  id           Int          @id @default(autoincrement())
  className    String
  trainerId    Int
  scheduleTime DateTime
  capacity     Int          @default(20)
  trainer      Trainer      @relation(fields: [trainerId], references: [id], onDelete: Cascade)
  attendance   Attendance[]
}

